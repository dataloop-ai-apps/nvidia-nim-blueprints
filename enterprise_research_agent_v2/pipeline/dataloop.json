              "moduleName": "enterprise-research-v2-module",
              "packageName": "nvidia-aiq-enterprise-research-v2"
            },
            "appName": "NVIDIA AIQ Enterprise Research Agent v2",
            "dpkName": "nvidia-aiq-enterprise-research-v2",
            "metadata": {
              "position": { "x": 9800, "y": 10300, "z": 0 },
              "componentGroupName": "NVIDIA AIQ Enterprise Research v2",
              "repeatable": true,
              "pipelineNodeName": "aiq-v2-intent-classifier-node"
            }
          },
          {
            "id": "node-shallow",
            "inputs": [
              {
                "portId": "port-shallow-in",
                "nodeId": "port-shallow-in",
                "type": "Item",
                "name": "item",
                "displayName": "item",
                "io": "input"
              }
            ],
            "outputs": [
              {
                "portId": "port-shallow-out",
                "nodeId": "port-shallow-out",
                "type": "Item",
                "name": "item",
                "displayName": "item",
                "actions": ["generate_report", "escalate"],
