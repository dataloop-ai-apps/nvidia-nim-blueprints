{
  "name": "video-search-summarization",
  "displayName": "Video Search and Summarization",
  "description": "Custom nodes for the VSS NVIDIA Blueprint: ASR inference (NVIDIA Riva gRPC) and Graph RAG (knowledge graph construction, retrieval, visualization).",
  "version": "0.0.67",
  "scope": "public",
  "attributes": {
    "Hub": ["Nvidia", "Dataloop"],
    "Category": ["Application"],
    "Application Type": "GenAI",
    "Provider": "NVIDIA",
    "Developed By": "Dataloop"
  },
  "components": {
    "computeConfigs": [
      {
        "name": "vss-compute-config",
        "runtime": {
          "podType": "regular-xs",
          "concurrency": 10,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/nvidia-nim-blueprints:0.0.4",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2
          }
        }
      },
      {
        "name": "graph-rag-compute-config",
        "runtime": {
          "podType": "regular-xs",
          "concurrency": 1,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/nvidia-nim-blueprints:0.0.4",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 1,
            "queueLength": 10
          }
        }
      }
    ],
    "pipelineNodes": [
      {
        "name": "asr-inference-node",
        "invoke": {
          "type": "function",
          "namespace": "vss-compute-config.vss-audio-module.predict"
        },
        "categories": ["Video Search and Summarization"],
        "scope": "project"
      },
      {
        "name": "add-chunk-to-graph",
        "invoke": {
          "type": "function",
          "namespace": "graph-rag-compute-config.graph-rag-module.add_chunk_to_graph"
        },
        "categories": ["Video Search and Summarization"],
        "displayName": "Add Chunk to Graph",
        "scope": "project"
      },
      {
        "name": "query-graph",
        "invoke": {
          "type": "function",
          "namespace": "graph-rag-compute-config.graph-rag-module.query_graph"
        },
        "categories": ["Video Search and Summarization"],
        "displayName": "Query Graph",
        "scope": "project"
      },
      {
        "name": "export-graph",
        "invoke": {
          "type": "function",
          "namespace": "graph-rag-compute-config.graph-rag-module.export_graph"
        },
        "categories": ["Video Search and Summarization"],
        "displayName": "Export Graph",
        "scope": "project"
      }
    ],
    "modules": [
      {
        "name": "vss-audio-module",
        "computeConfig": "vss-compute-config",
        "entryPoint": "video_search_summarization/vss_nodes/asr_inference.py",
        "className": "ASRInference",
        "integrations": [
          "dl-ngc-api-key"
        ],
        "functions": [
          {
            "name": "predict",
            "input": [
              {"name": "item", "type": "Item"}
            ],
            "output": [
              {"name": "item", "type": "Item"}
            ],
            "displayName": "ASR Inference"
          }
        ]
      },
      {
        "name": "graph-rag-module",
        "computeConfig": "graph-rag-compute-config",
        "entryPoint": "video_search_summarization/vss_nodes/graph_rag.py",
        "className": "ServiceRunner",
        "functions": [
          {
            "name": "add_chunk_to_graph",
            "input": [
              {"name": "item", "type": "Item"}
            ],
            "output": [
              {"name": "item", "type": "Item"}
            ],
            "displayName": "Add Chunk to Graph"
          },
          {
            "name": "query_graph",
            "input": [
              {"name": "item", "type": "Item"}
            ],
            "output": [
              {"name": "item", "type": "Item"}
            ],
            "displayName": "Query Graph"
          },
          {
            "name": "export_graph",
            "input": [
              {"name": "dataset", "type": "Dataset"}
            ],
            "output": [
              {"name": "item", "type": "Item"}
            ],
            "displayName": "Export Graph"
          }
        ]
      }
    ]
  }
}
