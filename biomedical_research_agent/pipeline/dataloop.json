              {
                "portId": "port-agent-in",
                "nodeId": "port-agent-in",
                "type": "Item",
                "name": "item",
                "displayName": "item",
                "io": "input"
              }
            ],
            "outputs": [
              {
                "portId": "port-agent-out",
                "nodeId": "port-agent-out",
                "type": "Item",
                "name": "item",
                "displayName": "item",
                "actions": ["research", "virtual_screening", "generate_report"],
