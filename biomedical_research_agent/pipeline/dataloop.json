              "componentGroupName": "NVIDIA Biomedical Research",
              "repeatable": true,
              "pipelineNodeName": "biomed-agent-node"
            }
          },
          {
            "id": "node-research",
            "inputs": [
              {
                "portId": "port-research-in",
